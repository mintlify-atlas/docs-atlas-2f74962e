  "keyFeatures": [
    "Pattern-based AST rules for detecting common security issues in Go code",
    "SSA-based analyzers for type conversions, slice bounds, crypto, and context propagation",
    "Taint analysis for tracking data flow from user input to dangerous sinks (SQL injection, command injection, path traversal, SSRF, XSS, log injection)",
    "Multiple output formats: text, JSON, SARIF, YAML, CSV, JUnit XML, HTML, SonarQube, golint",
    "GitHub Actions integration with SARIF upload support",
    "AI-powered autofix suggestions via Gemini, Claude, or OpenAI",
    "nosec annotation support for suppressing false positives",
    "CWE mapping for every detected issue",
    "Docker image available at ghcr.io/securego/gosec"
  ],
  "publicApiSurface": [
    "gosec ./...",
    "gosec -fmt=json -out=results.json ./...",
    "gosec -fmt=sarif -out=results.sarif ./...",
    "gosec -include=G101,G203,G401 ./...",
    "gosec -exclude=G303 ./...",
    "gosec -severity medium ./...",
    "gosec -confidence medium ./...",
    "gosec -tests ./...",
    "gosec -exclude-generated ./...",
    "gosec -conf config.json ./...",
    "gosec -track-suppressions -fmt=sarif -out=results.sarif ./...",
    "gosec -ai-api-provider=gemini-2.0-flash -ai-api-key=KEY ./...",
    "gosec --exclude-rules='cmd/.*:G204,G304' ./...",
    "gosec -nosec=true ./...",
    "gosec -tags debug,ignore ./...",
    "gosec -no-fail ./..."
  ]
}
